# Local development environment — copy to .env and fill in values
# Do NOT commit .env to version control

COMPOSE_FILE=docker/docker-compose.yml
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
FOOTBAG_DB_PATH=./database/footbag.db
PUBLIC_BASE_URL=http://localhost:3000
# SESSION_SECRET — sensitive. Never commit a real value. Production guards reject
# any value containing "changeme" or shorter than 32 chars. Generate fresh per
# environment with:  openssl rand -hex 32
SESSION_SECRET=changeme-use-a-long-random-string-in-production
# STUB_PASSWORD seeds the local preview member via legacy_data/scripts/seed_members.py.
STUB_PASSWORD=

# Express trust-proxy setting. Controls how req.ip and rate-limit keys resolve
# through X-Forwarded-For. Accepts an integer (hop count), 'true'/'false', or
# a comma-separated subnet list. Default: 2 in production (CloudFront + nginx),
# 0 otherwise. Leave unset for sensible defaults.
# TRUST_PROXY=2

# SES_SANDBOX_MODE signals that the deployment is subject to AWS SES sandbox
# recipient-verification limits. When true, email-gated pages (e.g.
# /register/check-email) render a warning that verification mail only reaches
# pre-verified recipients. Dev (SES_ADAPTER=stub) ignores this flag; staging
# sets it to 1; production flips it to 0 once SES production access is granted.
# Accepts '1', '0', 'true', 'false'. Default: false.
# SES_SANDBOX_MODE=0

