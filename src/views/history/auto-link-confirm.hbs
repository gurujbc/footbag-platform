{{! Verification-time auto-link confirmation. }}
{{! Renders the Tier 1 / Tier 2 candidate HP with explicit yes/no actions. }}
{{! The "yes" form POSTs to /history/auto-link/confirm, which re-validates }}
{{! the classifier output and commits via claimHistoricalPerson in one turn. }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>Based on the email and name on your account, we believe this historical player record refers to you. Confirm to carry Hall of Fame status, country, and career results onto your profile.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.error}}
      <p class="form-error" role="alert">{{content.error}}</p>
    {{/if}}

    {{#if content.personName}}
      <div class="card" style="margin-bottom:24px;">
        <p style="margin:0; font-weight:500;">Historical record: {{content.personName}}</p>
      </div>

      <p>Clicking confirm will link this historical record to your account.</p>

      <form method="POST" action="/history/auto-link/confirm">
        <input type="hidden" name="personId" value="{{content.personId}}" />
        <button type="submit" class="btn btn-primary">Yes, this is me — link my account</button>
      </form>
    {{/if}}

    <p style="margin-top:16px">
      <a href="{{content.declineHref}}">No, not me — take me to my dashboard</a>
    </p>
  </section>
</div>
