{
  "name": "footbag-platform",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "IFPA Footbag Platform — current deployed public baseline and long-term community platform",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run --exclude 'tests/smoke/**'",
    "test:watch": "vitest --exclude 'tests/smoke/**'",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:smoke": "scripts/test-smoke.sh",
    "test:coverage": "vitest run --exclude 'tests/smoke/**' --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "3.1031.0",
    "@aws-sdk/client-ses": "3.1031.0",
    "@aws-sdk/client-sts": "3.1031.0",
    "@playwright/test": "^1.58.2",
    "@types/busboy": "^1.5.4",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-handlebars": "^7.1.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.1",
    "supertest": "^7.0.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
