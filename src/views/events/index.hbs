{{! Events landing page — upcoming events + archive year links }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Past events by year ─────────────────────────────────────── }}
  {{#if content.archiveYears.length}}
  <section>
    <div class="section-heading">
      <h2>Past Events</h2>
    </div>
    <p class="text-muted mb-4">Browse completed events and results by year.</p>
    <div class="year-grid">
      {{#each content.archiveYears}}
        <a href="/events/year/{{this}}" class="year-pill">{{this}}</a>
      {{/each}}
    </div>
    <p class="text-muted" style="margin-top: 16px; font-size: 0.9rem;">Results data before 1997 is incomplete. More historical results are coming soon.</p>
  </section>
  {{/if}}

  {{! ── Upcoming events ─────────────────────────────────────────── }}
  <section>
    <div class="section-heading">
      <h2>Upcoming Events</h2>
    </div>

    <div class="card-grid">

      {{#if content.featuredPromo}}
        <div class="card card-featured">
          <div class="card-title">
            <a href="{{content.featuredPromo.href}}" {{#if content.featuredPromo.external}}target="_blank" rel="noopener noreferrer"{{/if}}>
              {{content.featuredPromo.title}}
            </a>
          </div>
          <div class="card-meta">
            <span>{{formatDate content.featuredPromo.startDate}} – {{formatDate content.featuredPromo.endDate}}</span>
            <span>{{formatLocation content.featuredPromo.city content.featuredPromo.region content.featuredPromo.country}}</span>
          </div>
          {{#if content.featuredPromo.description}}
            <p class="card-description">{{content.featuredPromo.description}}</p>
          {{/if}}
          <a href="{{content.featuredPromo.href}}" {{#if content.featuredPromo.external}}target="_blank" rel="noopener noreferrer"{{/if}} class="btn btn-white" style="margin-top: 16px;">{{content.featuredPromo.ctaLabel}}</a>
        </div>
      {{/if}}

      {{#each content.upcomingEvents}}
        {{> event-card}}
      {{/each}}

    </div>
  </section>

</div>
