<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#each navigation.contextLinks}}
      <a href="{{href}}" class="back-link">&#8592; {{label}}</a>
    {{/each}}

    {{#if content.success}}
      <div class="form-success-banner" role="status">
        Your password has been changed.
      </div>
    {{/if}}

    {{#if content.error}}
      <div class="form-error-banner" role="alert">
        {{content.error}}
      </div>
    {{/if}}

    <form method="POST" action="/members/{{content.memberKey}}/edit/password" class="profile-edit-form">
      <div class="form-field">
        <label for="oldPassword">Current password</label>
        <input
          type="password"
          id="oldPassword"
          name="oldPassword"
          autocomplete="current-password"
          required
        />
      </div>

      <div class="form-field">
        <label for="newPassword">New password</label>
        <input
          type="password"
          id="newPassword"
          name="newPassword"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </div>

      <div class="form-field">
        <label for="confirmPassword">Confirm new password</label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Change password</button>
      </div>
    </form>
  </section>
</div>
