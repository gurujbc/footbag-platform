{{! /freestyle — portal landing page }}

<div class="hero hero-sm hero-with-mascot">
  <div class="hero-text">
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
  <img class="hero-mascot" src="{{content.mascotSrc}}" alt="{{content.mascotAlt}}" width="150" height="150">
</div>

<div class="wrapper freestyle-landing">

  {{! ── What is Freestyle Footbag? (single narrative section) ──────────────── }}
  <section class="content-section">
    <h2>{{content.intro.heading}}</h2>
    {{#each content.intro.paragraphs}}
    <p>{{this}}</p>
    {{/each}}
    {{#if content.demoVideo}}
    <figure class="demo-video">
      <video autoplay loop muted playsinline preload="metadata" poster="{{content.demoVideo.posterUrl}}">
        <source src="{{content.demoVideo.webmUrl}}" type="video/webm">
        <source src="{{content.demoVideo.mp4Url}}" type="video/mp4">
        <p>{{content.demoVideo.caption}}</p>
      </video>
      <figcaption>{{content.demoVideo.caption}}</figcaption>
    </figure>
    {{/if}}
  </section>

  {{! ── Competition Formats ────────────────────────────────────────────────── }}
  <section class="content-section">
    <h2>Competition Formats</h2>
    <div class="card-grid card-grid-2col">
      {{#each content.competitionFormats}}
      <div class="card format-card">
        <div class="card-title">{{title}}</div>
        <p>{{paragraph}}</p>
        <div class="video-embed">
          <iframe src="{{videoEmbedUrl}}" title="{{videoTitle}}" loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  {{! ── Portal cards (existing five) ───────────────────────────────────────── }}
  <section class="content-section">
    <div class="card-grid card-grid-2col">

      <div class="card">
        <div class="card-title">History &amp; ADD System</div>
        <p>
          ADD (Additional Degree of Difficulty) scoring and the evolution of freestyle
          vocabulary from the 1980s foundation through modifier stacking in the 2000s.
        </p>
        <div class="card-actions">
          <a href="/freestyle/history" class="btn btn-outline">Full history &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Competition</div>
        <p>
          Top competitors, podium counts, and event history from
          documented freestyle events (1980 to present).
          Derived from canonical competition records.
        </p>
        <div class="card-actions">
          <a href="/freestyle/competition" class="btn btn-outline">Competition history &rarr;</a>
          <a href="/freestyle/partnerships" class="btn btn-outline">Partnerships &rarr;</a>
        </div>
      </div>

      <div class="card{{#unless content.totalRecords}} card-coming-soon{{/unless}}">
        <div class="card-title">Passback Records</div>
        <p>
          Per-trick consecutive completion records from the freestyle
          passback community.
        </p>
        {{#if content.totalRecords}}
        <div class="card-actions">
          <a href="/freestyle/records" class="btn btn-outline">View records &rarr;</a>
          <a href="/freestyle/leaders" class="btn btn-outline">Leaderboard &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card{{#unless content.totalTricks}} card-coming-soon{{/unless}}">
        <div class="card-title">Trick Dictionary</div>
        <p>
          ADD values, categories, descriptions, base components, and modifier relationships.
        </p>
        {{#if content.totalTricks}}
        <div class="card-actions">
          <a href="/freestyle/tricks" class="btn btn-outline">Browse tricks &rarr;</a>
          <a href="/freestyle/moves"  class="btn btn-outline">Move sets &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card">
        <div class="card-title">Insights</div>
        <p>
          Data-driven sequence analysis across the history of freestyle footbag,
          from the foundational 1980s vocabulary to the modern European era.
        </p>
        <div class="card-actions">
          <a href="/freestyle/insights" class="btn btn-outline">Insights &rarr;</a>
        </div>
      </div>

    </div>
  </section>

  {{! ── Get started tiles (placeholders) ───────────────────────────────────── }}
  <section class="content-section">
    <h2>Get Started</h2>
    <div class="card-grid card-grid-3col get-started-tiles">
      {{#each content.getStartedTiles}}
      <a class="card card-tile{{#if comingSoon}} card-coming-soon{{/if}}" href="{{href}}">
        <div class="card-title">{{label}}</div>
        {{#if comingSoon}}<span class="badge badge-coming-soon">Coming soon</span>{{/if}}
      </a>
      {{/each}}
    </div>
  </section>

</div>
