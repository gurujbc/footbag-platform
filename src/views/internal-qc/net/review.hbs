{{! /internal/net/review — net enrichment QC / review tool }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p class="hero-subtitle">
      Operator review of net enrichment metadata.
      Summarises non-public QC items and discipline mapping issues.
      Not shown in public pages.
      <a href="/internal/net/review/summary">Priority Summary &rarr;</a>
      &middot; <a href="/internal/net/recovery-signals">Recovery Signals &rarr;</a>
    </p>
  </div>
</div>

<div class="wrapper">

  {{! ── Section B: Summary ─────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Summary</h2>
    </div>
    <div class="review-summary-grid">

      <div class="review-card">
        <h3>By Reason</h3>
        <table class="records-table records-table-sm">
          <thead><tr><th>Reason</th><th class="col-num">Count</th></tr></thead>
          <tbody>
            {{#each content.summary.byReason}}
            <tr>
              <td>{{#if reasonCode}}{{reasonCode}}{{else}}<em>none</em>{{/if}}</td>
              <td class="col-num">{{count}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <div class="review-card">
        <h3>By Priority</h3>
        <table class="records-table records-table-sm">
          <thead><tr><th>Priority</th><th class="col-num">Count</th></tr></thead>
          <tbody>
            {{#each content.summary.byPriority}}
            <tr>
              <td>{{priority}} — {{label}}</td>
              <td class="col-num">{{count}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <div class="review-card">
        <h3>By Status</h3>
        <table class="records-table records-table-sm">
          <thead><tr><th>Status</th><th class="col-num">Count</th></tr></thead>
          <tbody>
            {{#each content.summary.byStatus}}
            <tr>
              <td>{{status}}</td>
              <td class="col-num">{{count}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        <p class="detail-muted">Total: {{content.summary.totalItems}}</p>
      </div>

      {{#if content.summary.byClassification.length}}
      <div class="review-card">
        <h3>By Classification</h3>
        <table class="records-table records-table-sm">
          <thead><tr><th>Classification</th><th class="col-num">Count</th></tr></thead>
          <tbody>
            {{#each content.summary.byClassification}}
            <tr>
              <td><a href="/internal/net/review?classification={{value}}">{{label}}</a></td>
              <td class="col-num">{{count}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{/if}}

      {{#if content.summary.byDecision.length}}
      <div class="review-card">
        <h3>By Decision</h3>
        <table class="records-table records-table-sm">
          <thead><tr><th>Decision</th><th class="col-num">Count</th></tr></thead>
          <tbody>
            {{#each content.summary.byDecision}}
            <tr>
              <td><a href="/internal/net/review?decision={{value}}">{{label}}</a></td>
              <td class="col-num">{{count}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{/if}}

    </div>
  </section>

  {{! ── Section C: Filters ──────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Filter Items</h2>
    </div>
    <form method="GET" action="/internal/net/review" class="review-filter-form">
      <label>
        Reason
        <select name="reason">
          {{#each content.filterOptions.reasonCodes}}
          <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Priority
        <select name="priority">
          {{#each content.filterOptions.priorities}}
          <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Status
        <select name="status">
          {{#each content.filterOptions.statuses}}
          <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Event ID
        <input type="text" name="event" value="{{content.activeFilters.eventId}}" placeholder="event id..." />
      </label>
      <label>
        Classification
        <select name="classification">
          {{#each content.filterOptions.classifications}}
          <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Fix Type
        <select name="fix_type">
          {{#each content.filterOptions.fixTypes}}
          <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Decision
        <select name="decision">
          {{#each content.filterOptions.decisionStatuses}}
          <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <div class="review-filter-actions">
        <button type="submit">Apply</button>
        <a href="/internal/net/review" class="btn-link">Clear</a>
      </div>
    </form>
  </section>

  {{! ── Optional event context when filtering by event ─────────────── }}
  {{#if content.eventContext}}
  <div class="notice notice-info">
    Filtered to event: <strong>{{content.eventContext.title}}</strong>
    ({{content.eventContext.city}}, {{content.eventContext.country}} &middot; {{content.eventContext.startDate}})
    &mdash; <a href="{{content.eventContext.href}}">View net event page &rarr;</a>
  </div>
  {{/if}}

  {{! ── Section D: Review Items ─────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Review Items</h2>
      <span class="section-meta">{{content.totalFiltered}} shown</span>
    </div>

    {{#if content.items}}
    <div class="records-table-wrap">
      <table class="records-table records-table-sm">
        <thead>
          <tr>
            <th>Pri</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Event</th>
            <th>Discipline</th>
            <th>Message</th>
            <th>Imported</th>
            <th>Classification</th>
            <th>Fix Type</th>
            <th>Confidence</th>
            <th>Decision</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.items}}
          <tr>
            <td class="col-rank">{{priority}}&nbsp;<span class="detail-muted">{{priorityLabel}}</span></td>
            <td>{{#if reasonCode}}{{reasonCode}}{{else}}<em>—</em>{{/if}}</td>
            <td>{{status}}</td>
            <td>
              {{#if eventHref}}
                <a href="{{eventHref}}">{{#if eventTitle}}{{eventTitle}}{{else}}{{eventId}}{{/if}}</a>
              {{else if eventId}}
                {{eventId}}
              {{else}}
                <em>—</em>
              {{/if}}
            </td>
            <td>{{#if disciplineName}}{{disciplineName}}{{else if disciplineId}}{{disciplineId}}{{else}}<em>—</em>{{/if}}</td>
            <td>{{message}}</td>
            <td class="col-date">{{importedAt}}</td>
            <td>{{#if classificationLabel}}{{classificationLabel}}{{else}}<em>—</em>{{/if}}</td>
            <td>{{#if proposedFixTypeLabel}}{{proposedFixTypeLabel}}{{else}}<em>—</em>{{/if}}</td>
            <td>{{#if confidenceLabel}}{{confidenceLabel}}{{else}}<em>—</em>{{/if}}</td>
            <td>{{#if decisionStatusLabel}}{{decisionStatusLabel}}{{else}}<em>—</em>{{/if}}</td>
          </tr>
          <tr class="review-edit-row">
            <td colspan="11">
              <details>
                <summary>Edit</summary>
                <div class="review-edit-forms">
                  <form method="POST" action="/internal/net/review/{{id}}/classify" class="review-inline-form">
                    <fieldset>
                      <legend>Classification</legend>
                      <label>
                        Type
                        <select name="classification">
                          <option value="">— clear —</option>
                          <option value="retag_team_type"{{#if (eq classification 'retag_team_type')}} selected{{/if}}>Retag Team Type</option>
                          <option value="split_merged_discipline"{{#if (eq classification 'split_merged_discipline')}} selected{{/if}}>Split Merged Discipline</option>
                          <option value="quarantine_non_results_block"{{#if (eq classification 'quarantine_non_results_block')}} selected{{/if}}>Quarantine Non-Results Block</option>
                          <option value="parser_improvement"{{#if (eq classification 'parser_improvement')}} selected{{/if}}>Parser Improvement</option>
                          <option value="unresolved"{{#if (eq classification 'unresolved')}} selected{{/if}}>Unresolved</option>
                        </select>
                      </label>
                      <label>
                        Fix Type
                        <select name="proposed_fix_type">
                          <option value="">— clear —</option>
                          <option value="retag_team_type"{{#if (eq proposedFixType 'retag_team_type')}} selected{{/if}}>Retag Team Type</option>
                          <option value="rename_discipline"{{#if (eq proposedFixType 'rename_discipline')}} selected{{/if}}>Rename Discipline</option>
                          <option value="rename_and_retag"{{#if (eq proposedFixType 'rename_and_retag')}} selected{{/if}}>Rename &amp; Retag</option>
                          <option value="reshape_doubles_to_singles"{{#if (eq proposedFixType 'reshape_doubles_to_singles')}} selected{{/if}}>Reshape Doubles → Singles</option>
                          <option value="split_merged_discipline"{{#if (eq proposedFixType 'split_merged_discipline')}} selected{{/if}}>Split Merged Discipline</option>
                          <option value="quarantine_non_results_block"{{#if (eq proposedFixType 'quarantine_non_results_block')}} selected{{/if}}>Quarantine Non-Results Block</option>
                          <option value="parser_improvement"{{#if (eq proposedFixType 'parser_improvement')}} selected{{/if}}>Parser Improvement</option>
                        </select>
                      </label>
                      <label>
                        Confidence
                        <select name="classification_confidence">
                          <option value="">— clear —</option>
                          <option value="confirmed"{{#if (eq classificationConfidence 'confirmed')}} selected{{/if}}>Confirmed</option>
                          <option value="tentative"{{#if (eq classificationConfidence 'tentative')}} selected{{/if}}>Tentative</option>
                        </select>
                      </label>
                      <button type="submit">Save Classification</button>
                    </fieldset>
                  </form>
                  <form method="POST" action="/internal/net/review/{{id}}/decision" class="review-inline-form">
                    <fieldset>
                      <legend>Decision</legend>
                      <label>
                        Status
                        <select name="decision_status">
                          <option value="">— clear —</option>
                          <option value="fix_encoded"{{#if (eq decisionStatus 'fix_encoded')}} selected{{/if}}>Fix Encoded</option>
                          <option value="fix_active"{{#if (eq decisionStatus 'fix_active')}} selected{{/if}}>Fix Active</option>
                          <option value="deferred"{{#if (eq decisionStatus 'deferred')}} selected{{/if}}>Deferred</option>
                          <option value="wont_fix"{{#if (eq decisionStatus 'wont_fix')}} selected{{/if}}>Won't Fix</option>
                        </select>
                      </label>
                      <label>
                        Notes
                        <input type="text" name="decision_notes" value="{{decisionNotes}}" placeholder="decision notes..." />
                      </label>
                      <button type="submit">Save Decision</button>
                    </fieldset>
                  </form>
                </div>
              </details>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="empty-state">No items match the current filter.</div>
    {{/if}}
  </section>

  {{! ── Section E: Discipline Mapping Review ────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Discipline Mappings — Conflict / Review Needed</h2>
    </div>

    {{#if content.conflictDisciplines}}
    <div class="records-table-wrap">
      <table class="records-table records-table-sm">
        <thead>
          <tr>
            <th>Discipline ID</th>
            <th>Raw Name</th>
            <th>Canonical Group</th>
            <th>Method</th>
            <th>Conflict</th>
            <th>Review</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.conflictDisciplines}}
          <tr>
            <td class="col-id">{{disciplineId}}</td>
            <td>{{disciplineName}}</td>
            <td>{{#if canonicalGroup}}{{canonicalGroup}}{{else}}<em>—</em>{{/if}}</td>
            <td>{{matchMethod}}</td>
            <td class="col-rank">{{#if conflictFlag}}<span class="badge badge-warn">yes</span>{{else}}—{{/if}}</td>
            <td class="col-rank">{{#if reviewNeeded}}<span class="badge badge-warn">yes</span>{{else}}—{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="empty-state">No conflict or review-needed discipline mappings found.</div>
    {{/if}}
  </section>

</div>
