{{! Canonical single event page — details and/or results }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>{{formatLocation content.event.city content.event.region content.event.country}} &middot; {{formatDate content.event.startDate}}{{#unless (eq content.event.startDate content.event.endDate)}} – {{formatDate content.event.endDate}}{{/unless}}</p>
  </div>
</div>

<div class="wrapper">
  <section>
    <div class="event-detail">

      {{! ── Event header ──────────────────────────────────────── }}
      <div class="event-header">
        <div class="event-meta-row">
          <span>&#128197; {{formatDate content.event.startDate}}{{#unless (eq content.event.startDate content.event.endDate)}} – {{formatDate content.event.endDate}}{{/unless}}</span>
          <span>&#128205; {{formatLocation content.event.city content.event.region content.event.country}}</span>
          {{#if content.event.hostClub}}
            <span>&#127968; {{content.event.hostClub}}</span>
          {{/if}}
          <span class="badge badge-{{content.event.status}}">{{content.event.status}}</span>
        </div>

        {{#if content.event.externalUrl}}
          <a href="{{content.event.externalUrl}}" class="btn btn-outline event-external-link" target="_blank" rel="noopener noreferrer">
            Event Website &#8599;
          </a>
        {{/if}}
      </div>

      {{! ── Description ───────────────────────────────────────── }}
      {{#if content.event.description}}
        <p>{{content.event.description}}</p>
      {{/if}}

      {{! ── Disciplines ───────────────────────────────────────── }}
      {{#if content.disciplines.length}}
        <div class="mb-8">
          <h2>Disciplines</h2>
          <ul class="disciplines-list mt-3">
            {{#each content.disciplines}}
              <li class="discipline-tag">{{name}}{{#if teamTypeLabel}} ({{teamTypeLabel}}){{/if}}</li>
            {{/each}}
          </ul>
        </div>
      {{/if}}

      {{! ── Results ───────────────────────────────────────────── }}
      <div>
        <h2>Results</h2>
        {{#if content.hasResults}}
          {{#if content.isSparse}}
            <div class="no-results-notice mt-4">
              We know the data from this event is incomplete but we're showing what we have anyway.
            </div>
          {{/if}}
          <div class="mt-5">
            {{#each content.resultSections}}
              {{> result-section}}
            {{/each}}
          </div>
        {{else}}
          <div class="no-results-notice mt-4">
            Results are not yet available.
          </div>
        {{/if}}
      </div>

      {{#each navigation.contextLinks}}
        <div class="mt-10">
          <a href="{{href}}" class="btn btn-outline">{{label}}</a>
        </div>
      {{/each}}

    </div>
  </section>
</div>
