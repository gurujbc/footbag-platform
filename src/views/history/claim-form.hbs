{{! Legacy (old-site user account) claim lookup form }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>If you had a user account on the original footbag.org forum, you can link that <em>old-site account</em> to your current profile. This is different from your historical <em>competitive record</em>; if you played IFPA tournaments, claim that from the player's history page (link on your profile). A future update will require email verification to complete this claim.</p>
  </div>
</div>

<div class="wrapper">

  <section>
    {{#if content.error}}
      <p class="form-error" role="alert">{{content.error}}</p>
    {{/if}}

    {{#if content.message}}
      <p class="form-notice" role="status">{{content.message}}</p>
    {{/if}}

    {{#if content.candidates}}
      <div class="card mb-6">
        <p class="m-0 mb-2 fw-500">Possible matches for your name:</p>
        <ul class="m-0 pl-5">
          {{#each content.candidates}}
            <li><a href="/history/{{this.personId}}/claim">{{this.personName}}</a></li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    <form method="POST" action="/history/claim" class="login-form">
      <div class="form-field">
        <label for="identifier">Legacy identifier</label>
        <input
          type="text"
          id="identifier"
          name="identifier"
          value="{{content.identifier}}"
          placeholder="Legacy email, username, or member ID"
          required
        />
      </div>

      <button type="submit" class="btn btn-primary">Look up legacy account</button>
    </form>

    <p class="mt-6"><a href="/members/{{user.slug}}">Back to profile</a></p>
  </section>

</div>
