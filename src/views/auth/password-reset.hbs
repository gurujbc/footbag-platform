<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.error}}
      <div class="form-error-banner" role="alert">
        {{content.error}}
      </div>
    {{/if}}
    <form method="POST" action="/password/reset/{{content.token}}" class="profile-edit-form">
      <div class="form-field">
        <label for="newPassword">New password</label>
        <input
          type="password"
          id="newPassword"
          name="newPassword"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </div>
      <div class="form-field">
        <label for="confirmPassword">Confirm new password</label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          autocomplete="new-password"
          minlength="8"
          required
        />
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Set new password</button>
      </div>
    </form>
  </section>
</div>
