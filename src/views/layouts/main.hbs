<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Footbag{{#if seo.title}} {{seo.title}}{{else}} Worldwide{{/if}}</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="wrapper">
      <a href="/" class="site-logo">IFPA <span>Footbag Worldwide</span></a>
      <nav class="main-nav" aria-label="Main navigation">
        <a href="/" {{#if (eq currentSection 'home')}}class="active"{{/if}}>Home</a>
        <a href="/events" {{#if (eq currentSection 'events')}}class="active"{{/if}}>Events</a>
        <a href="/history" {{#if (eq currentSection 'history')}}class="active"{{/if}}>Players</a>
        <a href="/clubs" {{#if (eq currentSection 'clubs')}}class="active"{{/if}}>Clubs</a>
        <a href="/hof" {{#if (eq currentSection 'hof')}}class="active"{{/if}}>HoF</a>
        {{#if isAuthenticated}}
          <a href="/members/{{currentUser.slug}}" {{#if (eq currentSection 'members')}}class="active"{{/if}}>
            {{#if currentUser.displayName}}{{currentUser.displayName}}{{else}}My Profile{{/if}}
          </a>
          <form method="POST" action="/logout" class="nav-logout">
            <button type="submit" class="nav-logout-btn">Logout</button>
          </form>
        {{else}}
          <a href="/login">Login</a>
        {{/if}}
      </nav>
    </div>
  </header>

  <main>
    {{{body}}}
  </main>

  <footer class="site-footer">
    <div class="wrapper">
      <div>
        <div class="footer-brand">IFPA Footbag Worldwide</div>
        <div class="footer-tagline">International Footbag Players Association</div>
      </div>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/events">Events</a>
        <a href="/history">Players</a>
        <a href="/clubs">Clubs</a>
        <a href="/hof">HoF</a>
      </div>
    </div>
    <div class="wrapper">
      <div class="footer-copy">
        &copy; International Footbag Players Association. All rights reserved.
      </div>
    </div>
  </footer>

</body>
</html>
