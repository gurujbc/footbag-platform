{{! Simulated email card. Rendered on email-gated pages when the service
    returns a non-null view-model. Three modes: dev (table of captured stub
    messages), sandbox (one-line notice). Production renders nothing because
    the service returns null. }}

<style>
.sec-card { border: 1px solid #d0d7de; border-radius: 6px; padding: 1rem; margin-top: 1.5rem; background: #f6f8fa; }
.sec-card-dev { border-left: 4px solid #1f883d; }
.sec-card-sandbox { border-left: 4px solid #bf8700; background: #fff8c5; }
.sec-card h2 { margin-top: 0; font-size: 1.1rem; }
.sec-card .sec-body { white-space: pre-wrap; max-height: 200px; overflow: auto; margin: 0; font-size: 0.85em; }
.sec-card .sec-table td { vertical-align: top; }
.sec-card .sec-msgid { font-size: 0.75em; color: #656d76; }
.sec-card ul { margin: 0.25rem 0 0.5rem 1.25rem; }
.sec-card code { background: rgba(0,0,0,0.05); padding: 0 0.25rem; border-radius: 3px; }
</style>

{{#if (eq mode "dev")}}
<section class="sec-card sec-card-dev" aria-label="Simulated email (dev)">
  <h2>Simulated email (dev)</h2>
  <p>
    <code>SES_ADAPTER=stub</code> — no real mail was sent.
    Showing {{messages.length}} captured message(s); newest first.
    Restarting the server clears the buffer.
  </p>
  {{#if messages.length}}
    <div class="records-table-wrap" style="overflow-x:auto">
      <table class="records-table records-table-sm sec-table">
        <thead>
          <tr>
            <th>To</th>
            <th>From</th>
            <th>Subject</th>
            <th>Delivered At</th>
            <th>Link</th>
            <th>Body</th>
          </tr>
        </thead>
        <tbody>
          {{#each messages}}
            <tr>
              <td>{{to}}</td>
              <td>{{from}}</td>
              <td>
                {{subject}}
                <div class="sec-msgid">{{messageId}}</div>
              </td>
              <td>{{deliveredAt}}</td>
              <td>{{#if firstUrl}}<a href="{{firstUrl}}">Open</a>{{/if}}</td>
              <td><pre class="sec-body">{{bodyText}}</pre></td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{else}}
    <div class="empty-state">No messages sent yet.</div>
  {{/if}}
</section>
{{/if}}

{{#if (eq mode "sandbox")}}
<section class="sec-card sec-card-sandbox" aria-label="Staging email delivery notice">
  <h2>Staging: SES sandbox</h2>
  <p>Only pre-verified recipients get real mail. Ask Dave to be added.</p>
</section>
{{/if}}
