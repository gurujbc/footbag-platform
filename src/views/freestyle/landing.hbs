{{! /freestyle landing page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
    {{#if content.totalRecords}}
    <div class="hero-stats">
      <span>{{content.totalRecords}} records</span>
      <span>{{content.recordTypes}} disciplines</span>
    </div>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  <nav class="section-nav" aria-label="Freestyle sections">
    <a href="/freestyle/records" class="btn btn-primary">Records</a>
    <a href="/freestyle/leaders" class="btn btn-outline">Leaders</a>
    <a href="/freestyle/moves"   class="btn btn-outline">Move Sets</a>
    <a href="/freestyle/about"   class="btn btn-outline">About</a>
  </nav>

  {{#if content.topHolders}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Top Record Holders</h2>
    </div>
    <table class="records-table leaders-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Player</th>
          <th class="col-num">Records</th>
          <th>Top Trick</th>
          <th class="col-num">Count</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.topHolders}}
        <tr>
          <td class="col-rank">{{rank}}</td>
          <td>
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-num">{{recordCount}}</td>
          <td>{{#if topTrick}}{{topTrick}}{{else}}&mdash;{{/if}}</td>
          <td class="col-num">{{topValue}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="source-note"><a href="/freestyle/leaders">Full leaderboard &rarr;</a></p>
  </section>
  {{/if}}

  {{#if content.recentRecords}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Recent Records</h2>
    </div>
    <table class="records-table">
      <thead>
        <tr>
          <th>Trick</th>
          <th>Adds</th>
          <th class="col-num">Count</th>
          <th>Holder</th>
          <th>Date</th>
          <th>Video</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.recentRecords}}
        <tr class="record-row{{#if isProbable}} record-probable{{/if}}">
          <td class="col-trick">
            <span class="trick-name">{{trickName}}</span>
            {{#if sortName}}<span class="trick-sort-name">{{sortName}}</span>{{/if}}
          </td>
          <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
          <td class="col-num">{{valueNumeric}}</td>
          <td class="col-holder">
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-date">
            {{#if achievedDate}}
              {{achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
            {{else}}
              &mdash;
            {{/if}}
          </td>
          <td class="col-video">
            {{#if videoUrl}}
              <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
                 aria-label="Watch {{holderName}} {{trickName}} record video">
                ▶{{#if videoTimecode}} {{videoTimecode}}{{/if}}
              </a>
            {{else}}
              &mdash;
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="source-note"><a href="/freestyle/records">All records &rarr;</a></p>
  </section>
  {{/if}}

  <section class="content-section">
    <h2 class="section-heading">About Freestyle Footbag</h2>
    <p>
      Freestyle footbag is a discipline built on creativity, technical difficulty, and
      individual style. Unlike net footbag — which is scored on rallies and placement —
      freestyle rewards trick diversity, add difficulty, and sequence length.
    </p>
    <p>
      The records on this site track the best known per-trick consecutive completions
      from the freestyle passback community, sourced from video documentation.
    </p>
  </section>

</div>
