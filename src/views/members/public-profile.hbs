<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if content.hofMember}}<p class="hero-subtitle">Member of the Footbag Hall of Fame{{#if content.bapMember}} and the Big Add Posse{{/if}}</p>
    {{else if content.bapMember}}<p class="hero-subtitle">Member of the Footbag Big Add Posse</p>
    {{else if content.historicalPersonName}}<p class="hero-subtitle">Historical record: {{content.historicalPersonName}}</p>{{/if}}
    {{#if content.city}}<p>{{content.city}}{{#if content.country}}, {{content.country}}{{/if}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.avatarThumbUrl}}
    <div style="text-align:center; margin-bottom:24px">
      <img src="{{content.avatarThumbUrl}}" alt="{{content.displayName}}" class="profile-avatar-img" />
    </div>
    {{/if}}

    {{#if content.bio}}
    <div class="profile-section">
      <h2 class="profile-section-heading">About</h2>
      <p>{{content.bio}}</p>
    </div>
    {{/if}}

    {{#if content.eventGroups.length}}
    <div class="section-heading" style="margin-top: 28px;">
      <h2>Competitive Results</h2>
      <span class="section-count">{{content.eventGroups.length}} events</span>
    </div>

    {{#each content.eventGroups}}
      <div class="player-event-block">
        <div class="player-event-header">
          <a href="{{eventHref}}" class="player-event-title">{{eventTitle}}</a>
          <span class="player-event-meta">{{formatDate startDate}} &middot; {{formatLocation city "" eventCountry}}</span>
        </div>
        <table class="results-table player-results-table">
          <thead>
            <tr>
              <th>Discipline</th>
              <th>Place</th>
            </tr>
          </thead>
          <tbody>
            {{#each results}}
              <tr>
                <td>{{#if disciplineName}}{{disciplineName}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                <td class="placement-num {{#if (eq placement 1)}}gold{{else if (eq placement 2)}}silver{{else if (eq placement 3)}}bronze{{/if}}">
                  {{placement}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/each}}
    {{/if}}

  </section>
</div>
