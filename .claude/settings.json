{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(pgrep:*)",
      "Bash(date:*)",
      "Bash(sqlite3 database/footbag.db \"SELECT *)",
      "Bash(sqlite3 database/footbag.db \"PRAGMA *)",
      "Bash(sqlite3 database/footbag.db \".schema*)",
      "Bash(sqlite3 database/footbag.db \".tables*)",
      "Bash(sqlite3:*)",
      "Bash(curl:*)",
      "Bash(curl -I:*)",
      "Bash(curl --head:*)",
      "Bash(curl -sI:*)",
      "Bash(curl -Is:*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npx tsc*)",
      "Bash(npx vitest*)",
      "Bash(node --version*)",
      "Bash(npm --version*)",
      "Bash(git fetch*)",
      "Bash(git stash list*)",
      "Bash(git stash show:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(mkdir:*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_close"
    ],
    "ask": [
      "Bash(sed -i:*)",
      "Bash(sed --in-place:*)",
      "Bash(rm:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "Bash(chgrp -R:*)",
      "Bash(mv:*)",
      "Bash(cp -f:*)",
      "Bash(cp --force:*)",
      "Bash(ln -sf:*)",
      "Bash(ln -f:*)",
      "Bash(truncate:*)",
      "Bash(apt-get install*)",
      "Bash(apt-get remove*)",
      "Bash(apt-get purge*)",
      "Bash(apt-get update*)",
      "Bash(apt-get upgrade*)",
      "Bash(apt-get autoremove*)",
      "Bash(apt install*)",
      "Bash(apt remove*)",
      "Bash(apt purge*)",
      "Bash(dpkg -i:*)",
      "Bash(dpkg -r:*)",
      "Bash(dpkg --remove:*)",
      "Bash(pip install*)",
      "Bash(pip uninstall*)",
      "Bash(pipx install*)",
      "Bash(pipx uninstall*)",
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Bash(npm ci*)",
      "Bash(npm update*)",
      "Bash(gem install*)",
      "Bash(gem uninstall*)",
      "Bash(cargo install*)",
      "Bash(cargo uninstall*)",
      "Bash(go install*)",
      "Bash(brew install*)",
      "Bash(brew uninstall*)",
      "Bash(brew upgrade*)",
      "Bash(systemctl start*)",
      "Bash(systemctl stop*)",
      "Bash(systemctl restart*)",
      "Bash(systemctl reload*)",
      "Bash(systemctl enable*)",
      "Bash(systemctl disable*)",
      "Bash(systemctl mask*)",
      "Bash(systemctl unmask*)",
      "Bash(systemctl daemon-reload*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose restart*)",
      "Bash(docker compose stop*)",
      "Bash(docker compose rm*)",
      "Bash(docker compose build*)",
      "Bash(docker compose pull*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -d*)",
      "Bash(git checkout --*)",
      "Bash(git restore*)",
      "Bash(git branch -D*)"
    ],
    "deny": [
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./secrets/**)",
      "Read(./.secrets/**)",
      "Read(./.claude/settings.local.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/*.crt)",
      "Read(./**/*.cer)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Read(./**/id_ecdsa)",
      "Read(./**/.aws/credentials)",
      "Read(./**/.aws/config)",
      "Read(./**/.ssh/**)",
      "Read(./.git/config)",
      "Read(./**/*.tfstate)",
      "Read(./**/*.tfstate.*)",
      "Read(./**/.npmrc)",
      "Read(./**/.terraformrc)",
      "Bash(dd:*)",
      "Bash(mkfs*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(gdisk:*)",
      "Bash(sgdisk:*)",
      "Bash(mkswap:*)",
      "Bash(swapoff:*)",
      "Bash(swapon:*)",
      "Bash(reboot*)",
      "Bash(shutdown:*)",
      "Bash(halt*)",
      "Bash(poweroff*)",
      "Bash(init 0*)",
      "Bash(init 6*)",
      "Bash(passwd:*)",
      "Bash(chpasswd:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(groupadd:*)",
      "Bash(groupdel:*)",
      "Bash(groupmod:*)",
      "Bash(visudo*)",
      "Bash(iptables:*)",
      "Bash(ufw:*)",
      "Bash(firewall-cmd:*)",
      "Bash(nft:*)",
      "Bash(ipset:*)",
      "Bash(mount:*)",
      "Bash(umount:*)",
      "Bash(hostnamectl set-*)",
      "Bash(timedatectl set-*)",
      "Bash(localectl set-*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --aggressive*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git worktree remove*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-git-mutations.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-prod-ops.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-db-destructive.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-readonly-bash.sh"
          }
        ]
      }
    ]
  }
}
