{{! /net — net portal landing page }}

<div class="hero hero-sm hero-with-mascot">
  <div class="hero-text">
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
  <img class="hero-mascot" src="{{content.mascotSrc}}" alt="{{content.mascotAlt}}" width="150" height="150">
</div>

<div class="wrapper net-landing">

  {{! ── What is Footbag Net? ──────────────────────────────────────── }}
  <section class="content-section">
    <h2>{{content.intro.heading}}</h2>
    {{#each content.intro.paragraphs}}
    <p>{{this}}</p>
    {{/each}}
  </section>

  {{! ── Competition Formats ───────────────────────────────────────── }}
  <section class="content-section">
    <h2>Competition Formats</h2>
    <div class="card-grid card-grid-2col">
      {{#each content.competitionFormats}}
      <div class="card format-card">
        <div class="card-title">{{title}}</div>
        <p>{{paragraph}}</p>
        <div class="video-embed">
          <iframe src="{{videoEmbedUrl}}" title="{{videoTitle}}" loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  {{! ── Explore (portal cards into existing net sub-routes) ───────── }}
  <section class="content-section">
    <div class="card-grid card-grid-2col">
      {{#each content.exploreCards}}
      <div class="card{{#if comingSoon}} card-coming-soon{{/if}}">
        <div class="card-title">{{label}}</div>
        <p>{{paragraph}}</p>
        {{#if comingSoon}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{else}}
        <div class="card-actions">
          <a href="{{href}}" class="btn btn-outline">{{linkLabel}} &rarr;</a>
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>

  {{! ── Notable Partnerships (existing real data) ─────────────────── }}
  {{#if content.notablePartnerships.length}}
  {{#each content.notablePartnerships}}
  <section class="content-section">
    <h2>{{title}}</h2>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Partnership</th>
            <th class="col-num">Apps</th>
            <th class="col-rank">Wins</th>
            <th class="col-rank">Podiums</th>
            <th>Years</th>
          </tr>
        </thead>
        <tbody>
          {{#each partnerships}}
          <tr>
            <td><a href="{{{teamHref}}}">{{teamName}}</a></td>
            <td class="col-num">{{appearanceCount}}</td>
            <td class="col-rank">{{winCount}}</td>
            <td class="col-rank">{{podiumCount}}</td>
            <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Notable Players (existing real data) ──────────────────────── }}
  {{#if content.notablePlayers.length}}
  {{#each content.notablePlayers}}
  <section class="content-section">
    <h2>{{title}}</h2>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Player</th>
            <th class="col-num">Apps</th>
            <th class="col-rank">Wins</th>
            <th class="col-rank">Podiums</th>
            <th>Years</th>
            <th class="col-num">Partners</th>
          </tr>
        </thead>
        <tbody>
          {{#each players}}
          <tr>
            <td><a href="{{{href}}}">{{personName}}</a>{{#if country}} <span class="detail-muted">{{country}}</span>{{/if}}</td>
            <td class="col-num">{{totalAppearances}}</td>
            <td class="col-rank">{{totalWins}}</td>
            <td class="col-rank">{{totalPodiums}}</td>
            <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
            <td class="col-num">{{partnerCount}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Recent Events ─────────────────────────────────────────────── }}
  {{#if content.recentEvents}}
  <section class="content-section">
    <h2>Recent Events</h2>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Event</th>
            <th class="col-num">Results</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each content.recentEvents}}
          <tr>
            <td><a href="{{eventHref}}">{{eventTitle}}</a> <span class="detail-muted">{{eventYear}}</span></td>
            <td class="col-num">{{appearanceCount}}</td>
            <td>{{#if hasMultiStageHint}}<span class="badge badge-warn">Multi-stage</span>{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/if}}

</div>
