{{! Legacy account claim confirmation page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>Review the legacy record below and confirm to link it to your current account.</p>
  </div>
</div>

<div class="wrapper">

  <section>
    <div class="card mb-6">
      <p class="m-0 fw-500">Legacy record: {{content.displayName}}</p>
      {{#if content.legacyMemberId}}
        <p class="m-0 mt-1 text-muted">Legacy member ID: {{content.legacyMemberId}}</p>
      {{/if}}
      {{#if content.country}}
        <p class="m-0 mt-1 text-muted">Country: {{content.country}}</p>
      {{/if}}
      {{#if content.isHof}}
        <p class="m-0 mt-1 fw-500 text-secondary">Hall of Fame member</p>
      {{/if}}
      {{#if content.isBap}}
        <p class="m-0 mt-1 fw-500 text-secondary">BAP member</p>
      {{/if}}
    </div>

    <p>This will link the legacy identity and honor status to your current account. Your current login credentials, display name, and any existing profile data will not be changed.</p>

    <div class="notice-card notice-card--info-blue my-4">
      <p class="m-0">Early access: This claim is processed immediately without email verification. A future update will require you to verify ownership via the legacy email address before the claim is finalized.</p>
    </div>

    <form method="POST" action="/history/claim/confirm">
      <input type="hidden" name="legacyMemberId" value="{{content.legacyMemberId}}" />
      <button type="submit" class="btn btn-primary">Confirm and link legacy account</button>
    </form>

    <p class="mt-4"><a href="/history/claim">Cancel</a></p>
  </section>

</div>
