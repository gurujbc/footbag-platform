{{! Reusable candidates table — used by both flat and grouped views in candidates.hbs }}
<div class="records-table-wrap">
  <table class="records-table records-table-sm">
    <thead>
      <tr>
        <th>Confidence</th>
        <th>Status</th>
        <th>Players</th>
        <th>Score</th>
        <th>Event / Year</th>
        <th>Raw Text</th>
        <th>Source</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr class="{{confidenceClass}}">
        <td class="col-rank">
          {{#if (eq confidenceLabel 'high')}}<span class="badge badge-ok">{{confidenceLabel}}</span>{{/if}}
          {{#if (eq confidenceLabel 'medium')}}<span class="badge badge-warn">{{confidenceLabel}}</span>{{/if}}
          {{#if (eq confidenceLabel 'low')}}<span class="badge badge-muted">{{confidenceLabel}}</span>{{/if}}
          {{#if (eq confidenceLabel 'unknown')}}<span class="detail-muted">{{confidenceLabel}}</span>{{/if}}
          {{#if confidenceScore}}<br><span class="detail-muted">{{confidenceScore}}</span>{{/if}}
        </td>
        <td>{{reviewStatus}}</td>
        <td>
          {{#if isFullyLinked}}
            {{#if playerAName}}<a href="{{playerAHref}}">{{playerAName}}</a>{{else}}{{playerAPersonId}}{{/if}}
            /
            {{#if playerBName}}<a href="{{playerBHref}}">{{playerBName}}</a>{{else}}{{playerBPersonId}}{{/if}}
          {{else}}
            {{#if playerARawName}}{{playerARawName}}{{else}}<em>unknown</em>{{/if}}
            /
            {{#if playerBRawName}}{{playerBRawName}}{{else}}<em>unknown</em>{{/if}}
            <span class="badge badge-warn">unlinked</span>
          {{/if}}
        </td>
        <td>{{#if extractedScore}}{{extractedScore}}{{else}}<em>—</em>{{/if}}</td>
        <td>
          {{#if eventHref}}
            <a href="{{eventHref}}">{{#if eventTitle}}{{eventTitle}}{{else}}{{eventId}}{{/if}}</a>
          {{else if eventId}}
            {{eventId}}
          {{else if yearHint}}
            {{yearHint}}
          {{else}}
            <em>—</em>
          {{/if}}
        </td>
        <td class="col-message">{{rawText}}</td>
        <td class="col-date detail-muted">{{sourceFile}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
