<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
      {{#if this.href}}<a href="{{this.href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <div class="hero-stats">
      <span>{{content.total}} clubs</span>
    </div>
  </div>
</div>

<div class="wrapper">

  {{#if content.regions}}

  {{#if content.hasMultipleRegions}}
  <nav class="club-country-nav" aria-label="Jump to region">
    <ul class="club-country-nav-list">
      {{#each content.regions}}
      {{#if region}}
      <li>
        <a href="#region-{{regionSlug}}">
          {{region}}
          <span class="club-country-count">{{clubs.length}}</span>
        </a>
      </li>
      {{/if}}
      {{/each}}
    </ul>
  </nav>
  {{/if}}

  {{#each content.regions}}
  <section {{#if regionSlug}}id="region-{{regionSlug}}"{{/if}} class="club-section">
    {{#if region}}
    <div class="section-heading">
      <h2>{{region}}</h2>
      <span class="section-count">{{clubs.length}}</span>
    </div>
    {{/if}}
    <ul class="club-list">
      {{#each clubs}}
      <li class="club-entry" data-club-id="{{clubId}}">
        <a href="{{clubHref}}" class="club-name">{{name}}</a>
        <span class="club-location">{{city}}</span>
        <span class="club-hashtag">{{standardTagDisplay}}</span>
        {{#if externalUrl}}
        <a href="{{externalUrl}}" class="club-external-link" target="_blank" rel="noopener noreferrer">website</a>
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </section>
  {{/each}}

  {{else}}
  <div class="empty-state">No clubs found.</div>
  {{/if}}

</div>
