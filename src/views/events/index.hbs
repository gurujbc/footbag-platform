{{! Events landing page — upcoming events + archive year links }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Featured promo hero ─────────────────────────────────────── }}
  {{#if content.featuredPromo}}
    <section class="event-hero">
      {{#if content.featuredPromo.imageUrl}}
        <a href="{{content.featuredPromo.href}}" {{#if content.featuredPromo.external}}target="_blank" rel="noopener noreferrer"{{/if}} class="event-hero-art-link">
          <img src="{{content.featuredPromo.imageUrl}}" alt="{{#if content.featuredPromo.imageAlt}}{{content.featuredPromo.imageAlt}}{{else}}{{content.featuredPromo.title}}{{/if}}" class="event-hero-art-img" />
        </a>
      {{/if}}
      <div class="event-hero-panel">
        <div class="event-hero-eyebrow">Featured Event</div>
        <h2 class="event-hero-title">
          <a href="{{content.featuredPromo.href}}" {{#if content.featuredPromo.external}}target="_blank" rel="noopener noreferrer"{{/if}}>
            {{content.featuredPromo.title}}
          </a>
        </h2>
        <div class="event-hero-meta">
          <span>{{formatDate content.featuredPromo.startDate}} – {{formatDate content.featuredPromo.endDate}}</span>
          <span>{{formatLocation content.featuredPromo.city content.featuredPromo.region content.featuredPromo.country}}</span>
        </div>
        {{#if content.featuredPromo.description}}
          <p class="event-hero-description">{{content.featuredPromo.description}}</p>
        {{/if}}
        <a href="{{content.featuredPromo.href}}" {{#if content.featuredPromo.external}}target="_blank" rel="noopener noreferrer"{{/if}} class="btn btn-white event-hero-cta">{{content.featuredPromo.ctaLabel}} →</a>
      </div>
    </section>
  {{/if}}

  {{! ── Past events by year ─────────────────────────────────────── }}
  {{#if content.archiveYears.length}}
  <section>
    <div class="section-heading">
      <h2>Past Events</h2>
    </div>
    <p class="text-muted mb-4">Browse completed events and results by year.</p>
    <div class="year-grid">
      {{#each content.archiveYears}}
        <a href="/events/year/{{this}}" class="year-pill">{{this}}</a>
      {{/each}}
    </div>
    <p class="text-muted mt-4 fs-sm">Results data before 1997 is incomplete. More historical results are coming soon.</p>
  </section>
  {{/if}}


</div>
