<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
    <div class="hero-stats">
      <span>{{content.memberCount}} historical members</span>
      <span>{{content.countryCount}} countries</span>
    </div>
  </div>
</div>

<div class="wrapper">

  <div class="card" style="margin-bottom:24px">
    <p class="card-description">For now you can browse players from our event-results database. These are historical records linked to competitive footbag results. Full member accounts and profiles are coming in a future release.</p>
  </div>

  <section>
    <div class="section-heading">
      <h2>Historical Records</h2>
      <span class="section-count">{{content.memberCount}}</span>
    </div>

    <div class="player-search-bar">
      <input
        type="text"
        id="member-search"
        placeholder="Search by name or country…"
        autocomplete="off"
      />
    </div>

    <table class="results-table" id="members-table">
      <thead>
        <tr>
          <th class="sortable sort-asc" data-col="0" data-type="text">Name</th>
          <th class="sortable" data-col="1" data-type="text">Country</th>
          <th class="sortable" data-col="2" data-type="num">Events</th>
          <th class="sortable" data-col="3" data-type="num">Placements</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.members}}
          <tr>
            <td><a href="{{memberHref}}">{{personName}}</a></td>
            <td>{{country}}</td>
            <td>{{eventCount}}</td>
            <td>{{placementCount}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="player-search-empty" id="member-search-empty" style="display:none">
      No members match your search.
    </p>

  </section>
</div>

<script>
  (function () {
    const table   = document.getElementById('members-table');
    const tbody   = table.querySelector('tbody');
    const input   = document.getElementById('member-search');
    const empty   = document.getElementById('member-search-empty');
    const headers = table.querySelectorAll('th[data-col]');

    let sortCol = 0, sortAsc = true;

    function applySearch() {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      Array.from(tbody.rows).forEach(function (row) {
        const match = !q || row.textContent.toLowerCase().includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      empty.style.display = visible === 0 ? '' : 'none';
    }
    input.addEventListener('input', applySearch);

    function sortTable(col, asc, type) {
      const rows = Array.from(tbody.rows);
      rows.sort(function (a, b) {
        const aText = a.cells[col].textContent.trim();
        const bText = b.cells[col].textContent.trim();
        const cmp = type === 'num'
          ? (parseInt(aText) || 0) - (parseInt(bText) || 0)
          : aText.localeCompare(bText);
        return asc ? cmp : -cmp;
      });
      rows.forEach(function (r) { tbody.appendChild(r); });
    }

    function updateSortClasses(active, asc) {
      headers.forEach(function (h) {
        h.classList.remove('sort-asc', 'sort-desc');
      });
      active.classList.add(asc ? 'sort-asc' : 'sort-desc');
    }

    headers.forEach(function (th) {
      th.addEventListener('click', function () {
        const col  = parseInt(th.dataset.col);
        const type = th.dataset.type;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = type === 'text';
        }
        sortTable(col, sortAsc, type);
        updateSortClasses(th, sortAsc);
        applySearch();
      });
    });

    updateSortClasses(headers[0], true);
  })();
</script>
