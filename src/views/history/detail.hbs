<div class="hero hero-sm">
  <div>
    {{#if page.eyebrow}}<div class="hero-eyebrow">{{page.eyebrow}}</div>{{/if}}
    <h1>{{page.title}}{{#if content.honorificNickname}} <span class="player-nickname">"{{content.honorificNickname}}"</span>{{/if}}</h1>
    <div class="hero-stats">
      {{#each content.summaryFacts}}
        <span>{{label}}: {{value}}</span>
      {{/each}}
    </div>
  </div>
</div>

<div class="wrapper">

  {{#if content.avatarThumbUrl}}
  <div style="text-align:center; margin-bottom:24px">
    <img src="{{content.avatarThumbUrl}}" alt="{{content.displayName}}" class="profile-avatar-img" />
  </div>
  {{/if}}

  {{#if content.hofMember}}
  <div class="card" style="margin-bottom:24px">
    <p class="card-description">{{content.displayName}} is a member of the Footbag Hall of Fame.</p>
  </div>
  {{else if content.bapMember}}
  <div class="card" style="margin-bottom:24px">
    <p class="card-description">{{content.displayName}} is a member of the Big Add Posse.</p>
  </div>
  {{else}}
  <div class="card" style="margin-bottom:24px">
    <p class="card-description">This is a historical record linked to competitive footbag results. It is not a current member account.</p>
  </div>
  {{/if}}

  <section>
    {{#each navigation.contextLinks}}
      <a href="{{href}}" class="back-link">&#8592; {{label}}</a>
    {{/each}}

    {{#if content.eventGroups.length}}
      <div class="section-heading" style="margin-top: 28px;">
        <h2>Historical Results</h2>
        <span class="section-count">{{content.eventGroups.length}} events</span>
      </div>

      {{#each content.eventGroups}}
        <div class="player-event-block">
          <div class="player-event-header">
            <a href="{{eventHref}}" class="player-event-title">{{eventTitle}}</a>
            <span class="player-event-meta">{{formatDate startDate}} &middot; {{formatLocation city "" eventCountry}}</span>
          </div>
          <table class="results-table player-results-table">
            <thead>
              <tr>
                <th>Discipline</th>
                <th>Place</th>
                <th>With</th>
              </tr>
            </thead>
            <tbody>
              {{#each results}}
                <tr>
                  <td>{{#if disciplineName}}{{disciplineName}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
                  <td class="placement-num {{#if (eq placement 1)}}gold{{else if (eq placement 2)}}silver{{else if (eq placement 3)}}bronze{{/if}}">
                    {{placement}}
                  </td>
                  <td>
                    {{#if (gt teammates.length 0)}}
                      {{#each teammates}}{{#unless @first}}, {{/unless}}{{#if playerHref}}<a href="{{playerHref}}">{{name}}</a>{{else}}{{name}}{{/if}}{{/each}}
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{/each}}

    {{else}}
      <div class="empty-state" style="margin-top: 40px;">
        <p>No historical results on record for this player.</p>
      </div>
    {{/if}}

  </section>
</div>
