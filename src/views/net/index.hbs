{{! /net — net doubles landing page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p class="hero-subtitle">Fast-paced volleyball-style play over a 5-foot net.</p>
  </div>
</div>

<div class="wrapper">

  {{! ── Notable Partnerships ──────────────────────────────────────── }}
  {{#if content.notablePartnerships.length}}
  {{#each content.notablePartnerships}}
  <section class="content-section">
    <h2>{{title}}</h2>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Partnership</th>
            <th class="col-num">Apps</th>
            <th class="col-rank">Wins</th>
            <th class="col-rank">Podiums</th>
            <th>Years</th>
          </tr>
        </thead>
        <tbody>
          {{#each partnerships}}
          <tr>
            <td><a href="{{{teamHref}}}">{{teamName}}</a></td>
            <td class="col-num">{{appearanceCount}}</td>
            <td class="col-rank">{{winCount}}</td>
            <td class="col-rank">{{podiumCount}}</td>
            <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Notable Players ───────────────────────────────────────────── }}
  {{#if content.notablePlayers.length}}
  {{#each content.notablePlayers}}
  <section class="content-section">
    <h2>{{title}}</h2>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Player</th>
            <th class="col-num">Apps</th>
            <th class="col-rank">Wins</th>
            <th class="col-rank">Podiums</th>
            <th>Years</th>
            <th class="col-num">Partners</th>
          </tr>
        </thead>
        <tbody>
          {{#each players}}
          <tr>
            <td><a href="{{{href}}}">{{personName}}</a>{{#if country}} <span class="detail-muted">{{country}}</span>{{/if}}</td>
            <td class="col-num">{{totalAppearances}}</td>
            <td class="col-rank">{{totalWins}}</td>
            <td class="col-rank">{{totalPodiums}}</td>
            <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
            <td class="col-num">{{partnerCount}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Explore ───────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="card-grid card-grid-3col">
      <div class="card card-coming-soon">
        <div class="card-title">Partnerships</div>
        <p>Browse all net doubles partnerships and their results.</p>
        <span class="badge badge-coming-soon">Coming soon</span>
      </div>
      <div class="card card-coming-soon">
        <div class="card-title">Teams</div>
        <p>View team rosters and competitive records.</p>
        <span class="badge badge-coming-soon">Coming soon</span>
      </div>
      <div class="card card-coming-soon">
        <div class="card-title">Events</div>
        <p>Full archive of net doubles competitions.</p>
        <span class="badge badge-coming-soon">Coming soon</span>
      </div>
    </div>
  </section>

  {{! ── Recent Events ────────────────────────────────────────────── }}
  {{#if content.recentEvents}}
  <section class="content-section">
    <h2>Recent Events</h2>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Event</th>
            <th class="col-num">Results</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each content.recentEvents}}
          <tr>
            <td><a href="{{eventHref}}">{{eventTitle}}</a> <span class="detail-muted">{{eventYear}}</span></td>
            <td class="col-num">{{appearanceCount}}</td>
            <td>{{#if hasMultiStageHint}}<span class="badge badge-warn">Multi-stage</span>{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/if}}

  {{! ── Data note ─────────────────────────────────────────────────── }}
  <p class="source-note">
    {{content.disclaimer}}
    Results reflect placements only; no match-level data is reconstructed.
  </p>

</div>
