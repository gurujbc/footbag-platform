{{! HoF landing page }}

<div class="hero">
  <div>
    <h1>{{page.title}}</h1>
    <p>{{page.intro}}</p>
  </div>
</div>

<div class="wrapper">

  <section>
    <div class="card">
      <div class="card-title">Coming Soon</div>
      <p class="card-description">{{page.notice}}</p>
      <div style="margin-top:20px">
        <a href="/" class="btn btn-outline">Home</a>
        <a href="/events" class="btn btn-outline" style="margin-left:12px">Events</a>
      </div>
    </div>
  </section>

  {{#each content.sections}}
  <section>
    <h2 class="section-heading">{{this.heading}}</h2>
    <p>{{this.body}}</p>
  </section>
  {{/each}}

</div>
