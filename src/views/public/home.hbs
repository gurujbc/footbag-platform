{{! Public home landing page }}

<div class="hero hero-sm">
  <div>
    <h1>{{hero.heading}}</h1>
    {{#if hero.subheading}}<p>{{hero.subheading}}</p>{{/if}}
    {{#if page.notice}}<div class="notice">{{page.notice}}</div>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section>
    <div class="card-grid card-grid-3col">
      {{#each primaryLinks}}
        <div class="card">
          <div class="card-title">{{label}}</div>
          <p class="card-description">{{description}}</p>
          <a href="{{href}}" class="btn {{#if (eq variant 'primary')}}btn-primary{{else}}btn-outline{{/if}}">{{label}}</a>
        </div>
      {{/each}}
    </div>
  </section>

  {{#if featuredUpcomingEvents.length}}
    <section>
      <div class="section-heading">
        <h2>Featured Upcoming Events</h2>
      </div>
      <div class="card-grid">
        {{#each featuredUpcomingEvents}}
          {{> event-card}}
        {{/each}}
      </div>
    </section>
  {{/if}}

</div>
