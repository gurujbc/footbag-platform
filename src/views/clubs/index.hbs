<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
    {{#if content.totalClubs}}
    <div class="hero-stats">
      <span>{{content.totalClubs}} clubs</span>
      <span>{{content.totalCountries}} countries</span>
    </div>
    {{/if}}
  </div>
</div>

<script type="application/json" id="clubs-map-data">{{{content.mapDataJson}}}</script>
<script src="/js/clubs-map.js" defer></script>

<div class="wrapper">

  <div id="clubs-map" hidden aria-hidden="true"></div>

  {{#if content.countries}}
  <ul class="club-country-index">
    {{#each content.countries}}
    <li class="club-country-index-entry">
      <a href="{{countryHref}}" class="club-country-index-link">
        {{country}}
      </a>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <div class="empty-state">No clubs found.</div>
  {{/if}}

</div>
