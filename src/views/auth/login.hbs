{{! Login page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section>
    <p class="text-muted">Member login is a work in progress. If you are in the loop and have the preview password, feel free to try it out.</p>

    {{#if content.error}}
      <p class="form-error" role="alert">{{content.error}}</p>
    {{/if}}

    <form method="POST" action="/login" class="login-form">
      {{#if content.returnTo}}
        <input type="hidden" name="returnTo" value="{{content.returnTo}}" />
      {{/if}}
      <div class="form-field">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" autocomplete="username" required />
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required />
      </div>
      <button type="submit" class="btn btn-primary">Log in</button>
    </form>
  </section>

</div>
