{{! /net/players/:personId — player net history overview }}

<div class="hero hero-sm">
  <div>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/net/teams">Net Teams</a> <span class="breadcrumb-sep">/</span>
      <span>{{page.title}}</span>
    </nav>
    <h1>{{page.title}}</h1>
    <div class="hero-stats">
      {{#if content.player.country}}<span>{{content.player.country}}</span>{{/if}}
      <span>{{content.player.totalAppearances}} net appearances</span>
      <span>{{content.totalPartners}} {{#if (eq content.totalPartners 1)}}partner{{else}}partners{{/if}}</span>
    </div>
  </div>
</div>

<div class="wrapper">

  <p class="source-note">{{content.disclaimer}}</p>

  {{#if content.careerHighlights.hasHighlights}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Career Highlights</h2>
    </div>
    <ul class="highlight-list">
      {{#if content.careerHighlights.mostFrequentPartner}}
      <li>Most frequent partner: <a href="{{{content.careerHighlights.mostFrequentPartner.partnerHref}}}">{{content.careerHighlights.mostFrequentPartner.partnerName}}</a> ({{content.careerHighlights.mostFrequentPartner.stat}})</li>
      {{/if}}
      {{#if content.careerHighlights.mostSuccessfulPartner}}
      <li>Most successful partnership: <a href="{{{content.careerHighlights.mostSuccessfulPartner.partnerHref}}}">{{content.careerHighlights.mostSuccessfulPartner.partnerName}}</a> ({{content.careerHighlights.mostSuccessfulPartner.stat}})</li>
      {{/if}}
      {{#if content.careerHighlights.longestPartnership}}
      <li>Longest partnership: <a href="{{{content.careerHighlights.longestPartnership.partnerHref}}}">{{content.careerHighlights.longestPartnership.partnerName}}</a> ({{content.careerHighlights.longestPartnership.stat}})</li>
      {{/if}}
      {{#if content.careerHighlights.careerSpan}}
      <li>Active span: {{content.careerHighlights.careerSpan}}</li>
      {{/if}}
    </ul>
  </section>
  {{/if}}

  {{#if content.partners}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Partners</h2>
    </div>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th>Partner</th>
            <th class="col-num">Together</th>
            <th class="col-rank">Best</th>
            <th>Years</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.partners}}
          <tr>
            <td class="col-rank">{{add @index 1}}</td>
            <td><a href="{{teamHref}}">{{partnerName}}</a></td>
            <td class="col-num">{{appearanceCount}}</td>
            <td class="col-rank">{{bestPlacementLabel}}</td>
            <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{else}}
  <div class="empty-state">No net competition history found.</div>
  {{/if}}

  {{#if content.topPartners.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Top Partners</h2>
    </div>
    <div class="records-table-wrap">
      <table class="records-table">
        <thead>
          <tr>
            <th>Partner</th>
            <th class="col-num">Appearances</th>
            <th class="col-num">Wins</th>
            <th class="col-num">Podiums</th>
            <th>Years</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.topPartners}}
          <tr>
            <td><a href="{{{partnerHref}}}">{{partnerName}}</a></td>
            <td class="col-num">{{appearanceCount}}</td>
            <td class="col-num">{{winCount}}</td>
            <td class="col-num">{{podiumCount}}</td>
            <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>
  {{/if}}

</div>
