{{! Events landing page — upcoming events + archive year links }}

<div class="hero hero-sm">
  <div>
    <h1>Footbag Events</h1>
    <p>Tournaments, competitions, and gatherings from around the world.</p>
  </div>
</div>

<div class="wrapper">

  {{! ── Past events by year ─────────────────────────────────────── }}
  {{#if archiveYears.length}}
  <section>
    <div class="section-heading">
      <h2>Past Events</h2>
    </div>
    <p class="text-muted mb-4">Browse completed events and results by year.</p>
    <div class="year-grid">
      {{#each archiveYears}}
        <a href="/events/year/{{this}}" class="year-pill">{{this}}</a>
      {{/each}}
    </div>
    <p class="text-muted" style="margin-top: 16px; font-size: 0.9rem;">Results data before 1997 is incomplete. More historical results are coming soon.</p>
  </section>
  {{/if}}

  {{! ── Upcoming events ─────────────────────────────────────────── }}
  <section>
    <div class="section-heading">
      <h2>Upcoming Events</h2>
    </div>

    <div class="card-grid">

      {{! 45th IFPA World Footbag Championships 2026 }}
      <div class="card card-featured">
        <div class="card-title">
          <a href="https://www.footbag.jp/FootbagWorlds2026" target="_blank" rel="noopener noreferrer">45th IFPA World Footbag Championships 2026</a>
        </div>
        <div class="card-meta">
          <span>10 August 2026 – 15 August 2026</span>
          <span>Tsukuba, Ibaraki, Japan</span>
        </div>
        <p class="card-description">Asia's first World Footbag Championship will be in Japan in August!</p>
        <a href="https://www.footbag.jp/FootbagWorlds2026" target="_blank" rel="noopener noreferrer" class="btn btn-white" style="margin-top: 16px;">Official Website</a>
      </div>

      {{#each upcomingEvents}}
        {{> event-card}}
      {{/each}}

    </div>
  </section>

</div>
