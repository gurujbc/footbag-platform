# Copy to terraform.tfvars and fill in all TODO values.
# Do NOT commit terraform.tfvars — it contains account-specific values.

environment    = "staging"
aws_region     = "us-east-1"
aws_account_id = "TODO-123456789012"

# Domain
# DEFERRED: leave empty for the initial CloudFront-only test deployment.
# The *.cloudfront.net URL works without a custom domain (see §29.5).
# Set to real values and follow the activation checklist in acm.tf when
# attaching a custom domain (NS-3).
domain_name     = ""
route53_zone_id = ""

# Lightsail
lightsail_bundle_id    = "nano_3_0"
lightsail_blueprint_id = "amazon_linux_2023"
ssh_public_key         = "TODO-ssh-ed25519 AAAA..."

# Notifications
alarm_email = "TODO-ops@example.com"

# State bucket (must match backend.tf)
state_bucket_suffix = "TODO-set-unique-suffix"

# ── Operator SSH access ───────────────────────────────────────────────────────
# Restrict SSH to your operator IP(s) only. Do not use 0.0.0.0/0.
# To find your current public IP: curl -s https://checkip.amazonaws.com
operator_cidrs = ["TODO-your-public-ip/32"]

# ── CloudFront two-pass bootstrap ─────────────────────────────────────────────
# First apply: set enable_cloudfront = false (creates Lightsail only).
# After first apply, construct the CloudFront origin hostname from the static IP.
# Lightsail does not provide public DNS hostnames — publicDnsName always returns None.
# For staging, use nip.io:
#   STATIC_IP=$(terraform output -raw lightsail_static_ip)
#   echo "${STATIC_IP}.nip.io"
# Then set lightsail_origin_dns to that value and enable_cloudfront = true.
# For production: use a real DNS A record pointing to the static IP instead.
# Second apply: creates the full stack including CloudFront.
enable_cloudfront    = false
lightsail_origin_dns = ""

# ── Monitoring gates ──────────────────────────────────────────────────────────
# Both default to false. See variables.tf descriptions before enabling.
enable_cwagent_alarms = false
enable_backup_alarm   = false
