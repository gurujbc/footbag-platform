<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{#if seo.fullTitle}}{{seo.fullTitle}}{{else}}Footbag{{#if seo.title}} {{seo.title}}{{else}} Worldwide{{/if}}{{/if}}</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="site-header">
    <div class="wrapper">
      <a href="/" class="site-logo">IFPA <span>Footbag Worldwide</span></a>
      <nav class="main-nav" aria-label="Main navigation">
        <a href="/" {{#if (eq currentSection 'home')}}class="active"{{/if}}>Home</a>
        <a href="/events" {{#if (eq currentSection 'events')}}class="active"{{/if}}>Events</a>
        <a href="/members" {{#if (eq currentSection 'members')}}class="active"{{/if}}>Members</a>
        <a href="/clubs" {{#if (eq currentSection 'clubs')}}class="active"{{/if}}>Clubs</a>
        <a href="/net" {{#if (eq currentSection 'net')}}class="active"{{/if}}>Net</a>
        <a href="/freestyle" {{#if (eq currentSection 'freestyle')}}class="active"{{/if}}>Freestyle</a>
        <a href="/records" {{#if (eq currentSection 'records')}}class="active"{{/if}}>Records</a>
        <a href="/hof" {{#if (eq currentSection 'hof')}}class="active"{{/if}}>HoF</a>
        {{#if isAuthenticated}}
          <a href="/members/{{currentUser.slug}}" {{#if (eq currentSection 'members')}}class="active"{{/if}}>
            {{#if currentUser.displayName}}{{currentUser.displayName}}{{else}}My Profile{{/if}}
          </a>
          <form method="POST" action="/logout" class="nav-logout">
            <button type="submit" class="nav-logout-btn">Logout</button>
          </form>
        {{else}}
          <a href="/login">Login</a>
        {{/if}}
      </nav>
    </div>
  </header>

  <main>
    {{#if flashLoggedOut}}
      <div class="flash-banner flash-logout" role="status">You have been logged out.</div>
    {{/if}}
    {{{body}}}
  </main>

  <footer class="site-footer">
    <div class="wrapper">
      <div class="footer-brand-block">
        <img src="/img/ifpa-logo.png" alt="IFPA" class="footer-logo" width="175" height="68" />
        <div class="footer-tagline">International Footbag Players Association</div>
      </div>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/events">Events</a>
        <a href="/members">Members</a>
        <a href="/clubs">Clubs</a>
        <a href="/net">Net</a>
        <a href="/freestyle">Freestyle</a>
        <a href="/records">Records</a>
        <a href="/hof">HoF</a>
      </div>
    </div>
    <div class="wrapper">
      <div class="footer-legal">
        <div class="footer-legal-links">
          <a href="/legal#privacy">Privacy</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/legal#terms">Terms</a>
          <span aria-hidden="true">&middot;</span>
          <a href="/legal#copyright">Copyright &amp; Trademarks</a>
        </div>
        <div class="footer-copy">
          &copy; 1983&ndash;2026 International Footbag Players Association. IFPA marks used with permission. &ldquo;Hacky Sack&rdquo; is a trademark of its respective owner, used descriptively.
        </div>
      </div>
    </div>
  </footer>

  <script src="/js/youtube-facade.js" defer></script>
  <script src="/js/auto-submit.js" defer></script>
</body>
</html>
